datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model BlogPost {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  summary     String
  content     String
  published   Boolean  @default(false)
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String
  slug      String     @unique
  blogs     BlogPost[]
  createdAt DateTime   @default(now())
}

model City {
  id                 Int                @id @default(autoincrement())
  name               String
  slug               String             @unique
  state              String?
  country            String
  countryCode        String
  population         Int?
  latitude           Float?
  longitude          Float?
  timezone           String?
  cityCurrencyPages  CityCurrencyPage[]
  createdAt          DateTime           @default(now())
}

model Currency {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  symbol    String?
  createdAt DateTime @default(now())
}

model ExchangeRate {
  id           Int      @id @default(autoincrement())
  fromCurrency String
  toCurrency   String
  rate         Float
  source       String?
  updatedAt    DateTime @default(now()) @updatedAt

  @@unique([fromCurrency, toCurrency])
}

model CityCurrencyPage {
  id              Int      @id @default(autoincrement())
  cityId          Int
  city            City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  fromCurrency    String
  toCurrency      String
  slug            String   @unique
  title           String
  metaDescription String?
  isIndexed       Boolean  @default(true)
  priority        Int      @default(0)
  createdAt       DateTime @default(now())
}

model SystemSetting {
  key   String @id
  value String
}
